            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[A07] 401 con password incorrecto', () => pm.response.to.have.status(401));",
                  "pm.test('[A07] Sin token en respuesta fallida', () => pm.expect(pm.response.json()).to.not.have.property('token'));",
                  "pm.test('[A07] Mensaje genérico — no revela existencia del usuario', () => {",
                  "  const err = pm.response.json().error.toLowerCase();",
                  "  pm.expect(err).to.not.include('not found');",
                  "  pm.expect(err).to.not.include('no existe');",
                  "});",
                  "pm.test('[A02] Sin hash bcrypt en respuesta', () => {",
                  "  const body = pm.response.text();",
                  "  pm.expect(body).to.not.include('$2b$');",
                  "  pm.expect(body).to.not.include('bcrypt');",
                  "});"
                ]
