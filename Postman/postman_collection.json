            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Ejecutar con Runner 10 iteraciones para provocar 429",
                  "pm.test('[A07] Servidor no devuelve 500 bajo intentos repetidos', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([401, 429]);",
                  "});",
                  "if (pm.response.code === 429) {",
                  "  pm.test('[A07] 429 con mensaje de rate limit', () => {",
                  "    pm.expect(pm.response.json().error).to.include('intentos');",
