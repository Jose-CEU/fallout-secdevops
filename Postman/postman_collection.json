  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const baseUrl = pm.environment.get('base_url') || 'http://localhost:5000';",
          "",
          "function autoLogin(username, password, tokenKey, cb) {",
          "    pm.sendRequest({",
          "        url: baseUrl + '/api/login',",
          "        method: 'POST',",
          "        header: [{ key: 'Content-Type', value: 'application/json' }],",
          "        body: { mode: 'raw', raw: JSON.stringify({ username, password }) }",
          "    }, (err, res) => {",
          "        if (!err && res && res.code === 200) {",
          "            const token = res.json().token;",
          "            pm.environment.set(tokenKey, token);",
          "            pm.collectionVariables.set(tokenKey, token);",
          "        }",
          "        if (cb) cb();",
          "    });",
          "}",
          "",
          "const ot = pm.environment.get('overseer_token');",
          "const dt = pm.environment.get('dweller_token');",
          "if (!ot || ot.length < 10) {",
          "    autoLogin('overseer', 'Overseer2077!', 'overseer_token', () => {",
          "        if (!dt || dt.length < 10) autoLogin('dweller', 'Dweller2077!', 'dweller_token');",
          "    });",
          "} else if (!dt || dt.length < 10) {",
          "    autoLogin('dweller', 'Dweller2077!', 'dweller_token');",
          "}"
        ]
      }
    }
  ]
