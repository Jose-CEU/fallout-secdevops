      "name": "P5 · Seguridad HTTP — A05",
      "description": "Security Misconfiguration: verifica cabeceras OWASP en todas las respuestas.",
      "item": [
        {
          "name": "🔴 Cabeceras OWASP en /api/health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[A05] X-Frame-Options: DENY', () => pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY'));",
                  "pm.test('[A05] X-Content-Type-Options: nosniff', () => pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff'));",
                  "pm.test('[A05] X-XSS-Protection presente', () => pm.expect(pm.response.headers.get('X-XSS-Protection')).to.exist);",
                  "pm.test('[A05] Cache-Control: no-store', () => pm.expect(pm.response.headers.get('Cache-Control')).to.include('no-store'));",
                  "pm.test('[A05] Content-Security-Policy presente', () => {",
                  "  const csp = pm.response.headers.get('Content-Security-Policy') || '';",
                  "  pm.expect(csp).to.include('default-src');",
                  "});"
                ]
              }
            }
          ]
        },
